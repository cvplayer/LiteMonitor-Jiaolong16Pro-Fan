{
  "id": "fan_speed",
  "meta": {
    "name": "风扇转速",
    "version": "1.0",
    "author": "LiteMonitor",
    "description": "从机械革命控制中心获取 CPU/GPU 风扇实时转速 (需运行 mqtt-http-bridge.js)"
  },
  "inputs": [],
  "execution": {
    "type": "chain",
    "interval": 5,
    "steps": [
      {
        "id": "get_fans",
        "url": "http://localhost:18900/fan",
        "extract": {
          "cpu_fan": "cpu_fan",
          "gpu_fan": "gpu_fan"
        }
      }
    ]
  },
  "process": [
    {
      "var": "cpu_color",
      "source": "cpu_fan",
      "function": "threshold_switch",
      "value_map": {
        "0": "0",
        "3000": "1",
        "4500": "2"
      }
    },
    {
      "var": "gpu_color",
      "source": "gpu_fan",
      "function": "threshold_switch",
      "value_map": {
        "0": "0",
        "3000": "1",
        "4500": "2"
      }
    }
  ],
  "outputs": [
    {
      "key": "cpu",
      "label": "CPU风扇",
      "short_label": "CPU",
      "format_val": "{{cpu_fan}}",
      "unit": "RPM",
      "color": "{{cpu_color}}"
    },
    {
      "key": "gpu",
      "label": "GPU风扇",
      "short_label": "GPU",
      "format_val": "{{gpu_fan}}",
      "unit": "RPM",
      "color": "{{gpu_color}}"
    }
  ]
}
